# Environment Configuration Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Database - SQLite by default (use PostgreSQL URL for production)
DATABASE_URL="file:./dev.db"

# Authentication - REQUIRED
# Generate a secure random string for JWT token signing
JWT_SECRET=your-secure-jwt-secret-key-here

# Development Test Credentials (remove in production)
# TEST_USER_USERNAME=admin
# TEST_USER_PASSWORD=admin123
# TEST_USER_ROLE=admin

# ============================================
# RATE LIMITING (Upstash Redis)
# ============================================
# Recommended for production with multiple instances
# Get credentials at https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# Airtable Integration (Optional)
# For content storage and tracking
# AIRTABLE_API_KEY=your-airtable-api-key
# AIRTABLE_BASE_ID=your-airtable-base-id
# AIRTABLE_TABLE_NAME=your-airtable-table-name

# Hugging Face API (Optional)
# For AI image generation
# HUGGING_FACE_API_KEY=your-hugging-face-api-key

# ============================================
# NOTIFICATION SERVICES (Optional)
# ============================================

# Email Notifications via Gmail
# EMAIL_USER=your-email@gmail.com
# GMAIL_CLIENT_ID=your-gmail-client-id
# GMAIL_CLIENT_SECRET=your-gmail-client-secret
# GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# Slack Notifications
# SLACK_TOKEN=your-slack-bot-token

# Twilio SMS Notifications
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ============================================
# PLATFORM API INTEGRATIONS (Optional)
# ============================================

# Facebook
# FACEBOOK_API_URL=https://graph.facebook.com
# FACEBOOK_API_KEY=your-facebook-api-key

# Instagram
# INSTAGRAM_API_URL=https://graph.instagram.com
# INSTAGRAM_API_KEY=your-instagram-api-key

# LinkedIn
# LINKEDIN_API_URL=https://api.linkedin.com
# LINKEDIN_API_KEY=your-linkedin-api-key

# Twitter/X
# TWITTER_API_URL=https://api.twitter.com
# TWITTER_API_KEY=your-twitter-api-key

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Node Environment (development, production, test)
# NODE_ENV=development

# Next.js specific
# NEXT_PUBLIC_API_URL=http://localhost:3000
