{
  "name": "content-creation-platform",
  "version": "1.0.0",
  "description": "A comprehensive content creation and management platform built with React and Next.js, featuring AI-powered text processing, image generation, and multi-platform publishing capabilities.",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "export": "next export",
    "deploy": "npm run build && npm run export",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check-all": "npm run type-check && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@slack/web-api": "^7.9.1",
    "axios": "^1.9.0",
    "dompurify": "^3.2.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "isomorphic-dompurify": "^2.33.0",
    "jsonwebtoken": "^9.0.2",
    "next": "latest",
    "nodemailer": "^7.0.11",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "twilio": "^5.5.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/airtable": "^0.10.5",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.6.2",
    "ts-jest": "^29.3.2",
    "typescript": "^5.3.3"
  },
  "author": "JustAGhosT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JustAGhosT/content_creation.git"
  },
  "keywords": [
    "content-creation",
    "nextjs",
    "react",
    "ai",
    "multi-platform",
    "publishing"
  ]
}
